# Copy this file to server/.env (and do NOT commit it)

PORT=5000

# Use your MongoDB Atlas connection string
MONGODB_URI=

# Auth (placeholders for now; Step 2 will require them)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# CORS
# Example: http://localhost:5173 (Vite default)
CORS_ORIGIN=http://localhost:5173

